# 개발 모드(Vite dev server)에서는 비워두면 됩니다 (자동 /api 프록시).
# 빌드 후 cloudflared 같이 외부 URL 로 띄울 때만 채웁니다.
# VITE_API_BASE_URL=https://your-tunnel.trycloudflare.com

# Kakao 지도 JavaScript Key
#   1. https://developers.kakao.com → 앱 생성
#   2. [앱 설정] → [플랫폼] → Web 플랫폼 등록 (http://localhost:5173)
#   3. [앱 키] → JavaScript 키 복사 후 아래에 붙여넣기
VITE_KAKAO_MAP_KEY=
