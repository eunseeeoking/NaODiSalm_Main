// Prisma 스키마 - 단일 소스 오브 트루스
//
// ─────────────── 명명 규칙 ───────────────
//   테이블:   t_{name}        (Prisma model 의 @@map 으로 매핑)
//   프로시저: p_{name}
//   뷰:      view_{name}      (raw SQL 마이그레이션)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
//  사용자 / 세션
// ──────────────────────────────────────────────────────────────

/// 사용자 (t_user) - 시스템 사용자 계정 정보
model User {
  id             Int       @id @default(autoincrement()) /// 고유 사용자 ID
  email          String    @unique /// 로그인 이메일 (유니크, 이메일 형식)
  password       String    /// bcrypt 해시값 (salt rounds=10, 최소 60자)
  name           String? /// 사용자 이름 (선택, 최대 100자)
  phone          String? /// 휴대폰번호 (선택, 형식: 010-1234-5678 또는 숫자만)
  createdAt      DateTime  @default(now()) @map("created_at") /// 계정 생성일시
  deletedAt      DateTime? @map("deleted_at") /// 계정 삭제일시 (soft delete, null이면 활성 사용자)
  loginFailCount Int       @default(0) @map("login_fail_count") /// 연속 로그인 실패 횟수 (3회 이상 시 계정 잠금)

  tokens UserToken[]

  @@map("t_user")
}

/// 세션 토큰 (t_user_token) - JWT 토큰 저장 및 세션 관리
model UserToken {
  id                Int       @id @default(autoincrement()) /// 토큰 레코드 ID
  userId            Int       @map("user_id") /// 사용자 ID (FK → t_user)
  refreshTokenHash  String    @unique @map("refresh_token_hash") /// Refresh JWT의 SHA256 해시 (보안: 원본 저장 금지)
  accessTokenHash   String?   @map("access_token_hash") /// Access JWT의 SHA256 해시 (선택, 필요시에만 저장)
  accessExpiresAt   DateTime? @map("access_expires_at") /// Access 토큰 만료 시각 (UTC, 기본 15분)
  refreshExpiresAt  DateTime  @map("refresh_expires_at") /// Refresh 토큰 만료 시각 (UTC, 기본 7일)
  rememberMe        Boolean   @default(false) @map("remember_me") /// "계정 기억" 옵션 여부 (true면 refreshExpiresAt 자동 연장)
  userAgent         String?   @map("user_agent") @db.VarChar(255) /// 로그인 시 브라우저 User-Agent (기기 감지/CSRF 방지)
  ipAddress         String?   @map("ip_address") @db.VarChar(64) /// 로그인 IP 주소 (IPv4/IPv6 형식)
  createdAt         DateTime  @default(now()) @map("created_at") /// 토큰 발급 시각
  revokedAt         DateTime? @map("revoked_at") /// 토큰 폐기 시각 (로그아웃 시 설정, 이전 토큰 무효화)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("t_user_token")
}

// ──────────────────────────────────────────────────────────────
//  부동산 데이터 (국토교통부 실거래가 ingest)
// ──────────────────────────────────────────────────────────────

/// 법정동 코드 마스터 (t_legal_dong) - 행정구역 기준 데이터 (한국 시도/시군구/읍면동)
///  - 국토부 API 의 LAWD_CD(5자리 시군구) 또는 10자리 풀코드 저장
///  - 정적 데이터 — 시드로 1회 적재, 변경 거의 없음
model LegalDong {
  code     String  @id @db.VarChar(10) /// LAWD_CD 코드: 5자리(시군구) 또는 10자리(풀 법정동) 형식. 예: "11680" (강남구), "1168010100" (강남구 강남동)
  sido     String  @db.VarChar(40) /// 시도명 (예: "서울특별시", "경기도")
  sigungu  String  @db.VarChar(60) /// 시군구명 (예: "강남구", "수원시 영통구")
  dong     String? @db.VarChar(60) /// 읍면동명 (선택, 10자리 코드일 때만 저장, 예: "강남동")
  isActive Boolean @default(true) @map("is_active") /// 활성 구역 여부 (폐지/통합된 행정구역은 false)

  @@map("t_legal_dong")
}

/// 아파트 단지 마스터 (t_apt_complex) - 아파트 단지 기본 정보
///  - 거래/전월세 데이터에서 fingerprint 로 중복 제거 후 등록
///  - 좌표는 별도 지오코딩 잡으로 채워짐 (최초엔 NULL)
model AptComplex {
  id          Int      @id @default(autoincrement()) /// 단지 고유 ID
  aptSeq      String?  @unique @map("apt_seq") @db.VarChar(40) /// MOLIT(국토부) 공식 단지 고유 ID (예: "11680-3621", 선택)
  name        String   @db.VarChar(120) /// 단지명 (예: "테헤란 푸르지오")
  sigunguCode String   @map("sigungu_code") @db.VarChar(5) /// 시군구 LAWD_CD (5자리, 예: "11680" 강남구)
  legalDong   String   @map("legal_dong") @db.VarChar(60) /// 법정동명 (예: "강남동", 주소 정규화용)
  jibun       String?  @db.VarChar(60) /// 지번 주소 (선택, 예: "강남구 강남동 1234")
  roadAddr    String?  @map("road_addr") @db.VarChar(200) /// 도로명 주소 (선택, 예: "서울 강남구 테헤란로 152")
  builtYear   Int?     @map("built_year") /// 준공년도 (선택, 연도만, 예: 2005, 면적별 분류용)
  lat         Float? /// WGS84 위도 (지오코딩으로 채움, 초기값 NULL)
  lng         Float? /// WGS84 경도 (지오코딩으로 채움, 초기값 NULL)
  createdAt   DateTime @default(now()) @map("created_at") /// 데이터 등록일시
  updatedAt   DateTime @updatedAt @map("updated_at") /// 데이터 마지막 수정일시

  trades AptTrade[]
  rents  AptRent[]

  /// aptSeq 가 없는 경우용 fallback fingerprint (중복 방지)
  @@unique([sigunguCode, legalDong, name, builtYear], map: "uniq_complex_fingerprint")
  @@index([sigunguCode, legalDong])
  @@map("t_apt_complex")
}

/// 아파트 매매 실거래 (t_apt_trade) - 아파트 매매 거래 기록 (국토교통부 실거래가)
model AptTrade {
  id          Int      @id @default(autoincrement()) /// 거래 레코드 ID
  complexId   Int      @map("complex_id") /// 아파트 단지 ID (FK → t_apt_complex)
  dealDate    DateTime @map("deal_date") @db.Date /// 거래 체결일 (년-월-일, 예: 2024-05-15)
  priceManwon Int      @map("price_manwon") /// 거래 가격 (만원 단위, 예: 50000은 5억원)
  areaM2      Float    @map("area_m2") /// 전용면적 (㎡, 소수점 가능, 예: 59.8)
  floor       Int? /// 층수 (선택, 1~40 등의 범위)
  builtYear   Int?     @map("built_year") /// 준공년도 (선택, 거래 당시 단지 나이)
  rawPayload  Json?    @map("raw_payload") /// 원본 응답 JSON (디버깅/감사 추적용, 선택)
  createdAt   DateTime @default(now()) @map("created_at") /// 데이터 수집/저장 시각

  complex AptComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  /// 같은 단지/일자/면적/층/가격의 거래는 동일 건으로 간주 → 재실행 시 중복 방지
  @@unique([complexId, dealDate, areaM2, floor, priceManwon], map: "uniq_trade")
  @@index([complexId, dealDate])
  @@map("t_apt_trade")
}

/// 아파트 전월세 (t_apt_rent) - 아파트 전월세 거래 기록 (국토교통부 실거래가)
enum RentType {
  JEONSE /// 전세 (보증금만 있고 월세 없음, monthlyManwon=0)
  WOLSE /// 월세 (보증금 + 월세)
}

model AptRent {
  id            Int      @id @default(autoincrement()) /// 전월세 레코드 ID
  complexId     Int      @map("complex_id") /// 아파트 단지 ID (FK → t_apt_complex)
  contractDate  DateTime @map("contract_date") @db.Date /// 계약 체결일 (년-월-일, 예: 2024-05-15)
  depositManwon Int      @map("deposit_manwon") /// 보증금 (만원 단위, 예: 50000은 5억원)
  monthlyManwon Int      @default(0) @map("monthly_manwon") /// 월세 (만원 단위), 전세는 0, 월세는 100 이상
  contractType  RentType @map("contract_type") /// 계약 유형 (JEONSE=전세, WOLSE=월세)
  areaM2        Float    @map("area_m2") /// 전용면적 (㎡, 소수점 가능, 예: 59.8)
  floor         Int? /// 층수 (선택, 1~40 등의 범위)
  builtYear     Int?     @map("built_year") /// 준공년도 (선택, 계약 당시 단지 나이)
  rawPayload    Json?    @map("raw_payload") /// 원본 응답 JSON (디버깅/감사 추적용, 선택)
  createdAt     DateTime @default(now()) @map("created_at") /// 데이터 수집/저장 시각

  complex AptComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@unique([complexId, contractDate, areaM2, floor, depositManwon, monthlyManwon], map: "uniq_rent")
  @@index([complexId, contractDate])
  @@map("t_apt_rent")
}

// ──────────────────────────────────────────────────────────────
//  ML 학습 결과 (2026_MOLIT_ML 에서 upsert)
// ──────────────────────────────────────────────────────────────

/// 아파트 면적 구간 분류 (m²당 단가 예측 모델 분할용)
enum AreaBucket {
  SMALL        /// 소형 (≤60㎡, 원룸/투룸 수준)
  MEDIUM       /// 중형 (60~85㎡, 일반 가정용 평형)
  LARGE_MID    /// 준대형 (85~135㎡, 넓은 가정용)
  LARGE        /// 대형 (>135㎡, 고급형 아파트)
}

/// 아파트 준공연도 구간 분류 (건물 상태 반영)
enum AgeBucket {
  NEW          /// 신축 (≤10년, 상태 좋음)
  SEMI_NEW     /// 준신축 (10~20년)
  MID          /// 중년 (20~30년)
  OLD          /// 노후 (>30년, 재개발/재건축 대상)
}

/// LSTM 학습 결과 (t_training_result) - 머신러닝 모델 예측 결과 저장소
///  - 단지 단위로 학습 (complex_id 채움) OR 구간 집계 단위로 학습 (complex_id null)
///  - 같은 모델 버전 + 같은 base_date + 같은 키 조합은 1 row 만 유지 (upsert)
model TrainingResult {
  id                    Int        @id @default(autoincrement()) /// 학습 결과 레코드 ID
  complexId             Int?       @map("complex_id") /// 아파트 단지 ID (선택, null이면 구간/지역 집계 결과)
  sigunguCode           String     @map("sigungu_code") @db.VarChar(5) /// 시군구 LAWD_CD (5자리, 예: "11680")
  legalDong             String     @map("legal_dong") @db.VarChar(60) /// 법정동명 (예: "강남동")
  areaBucket            AreaBucket @map("area_bucket") /// 면적 구간 분류 (SMALL/MEDIUM/LARGE_MID/LARGE)
  ageBucket             AgeBucket  @map("age_bucket") /// 준공연도 구간 분류 (NEW/SEMI_NEW/MID/OLD)
  baseDate              DateTime   @map("base_date") @db.Date /// 학습 기준일 (모델 입력 데이터의 마지막 시점)
  currentPricePerM2     Float      @map("current_price_per_m2") /// 현재 m²당 단가 (만원/㎡, baseDate 시점)
  predicted1yPricePerM2 Float?     @map("predicted_1y_price_per_m2") /// 1년 후 예측 m²당 단가 (만원/㎡, baseDate+1년)
  predicted3yPricePerM2 Float?     @map("predicted_3y_price_per_m2") /// 3년 후 예측 m²당 단가 (만원/㎡, baseDate+3년)
  expectedReturn3y      Float?     @map("expected_return_3y") /// 예상 3년 수익률 (%, 예: 15.5는 +15.5%)
  confidence            Float? /// 모델 신뢰도 (0~1 범위, 1.0이 최고, 0.5 이상 권장)
  mae                   Float? /// 검증 평균절대오차 (Mean Absolute Error, 만원/㎡)
  mape                  Float? /// 검증 평균절대백분율오차 (MAPE %, 예: 5.2는 ±5.2%)
  sampleCount           Int        @map("sample_count") /// 학습에 사용된 거래 샘플 수 (통계적 유의성 지표)
  modelVersion          String     @map("model_version") @db.VarChar(40) /// 모델 버전 ID (예: "lstm-v1", A/B 비교용)
  modelMeta             Json?      @map("model_meta") /// 모델 메타데이터 JSON (하이퍼파라미터, 학습 설정 등)
  trainedAt             DateTime   @default(now()) @map("trained_at") /// 모델 학습/저장 시각

  @@unique([sigunguCode, legalDong, areaBucket, ageBucket, complexId, baseDate, modelVersion], map: "uniq_training_result")
  @@index([sigunguCode, legalDong])
  @@index([complexId])
  @@index([trainedAt])
  @@map("t_training_result")
}

// ──────────────────────────────────────────────────────────────
//  통근시간 매트릭스 캐시 (ODsay 응답 영구 보관)
// ──────────────────────────────────────────────────────────────

/// 직장 ↔ 행정동 통근시간 매트릭스 (t_commute_matrix)
///  - cacheKey = 직장 좌표 4자리 반올림 ("37.4979_127.0276")
///    같은 빌딩 다른 층 입력해도 캐시 hit → ODsay 호출 0
///  - 신규 직장 첫 입력 시에만 ODsay 호출, 이후 영구 hit
///  - 90일 후 만료 정책은 추후 추가 (현재는 무기한 보관)
model CommuteMatrix {
  id               Int      @id @default(autoincrement()) /// 캐시 레코드 ID
  cacheKey         String   @map("cache_key") @db.VarChar(40) /// "lat_lng" 4자리 반올림, 직장 그룹화 키
  workLat          Float    @map("work_lat") /// 직장 위도 (원본, 디버그용)
  workLng          Float    @map("work_lng") /// 직장 경도 (원본, 디버그용)
  workLabel        String?  @map("work_label") @db.VarChar(120) /// 직장명 (예: "강남역", 디버그용)
  legalDongCode    String   @map("legal_dong_code") @db.VarChar(10) /// 행정동 코드 (10자리)
  transitMinutes   Int      @map("transit_minutes") /// 대중교통 통근시간 (분, ODsay)
  transitTransfers Int?     @map("transit_transfers") /// 환승 횟수 (지하철+버스)
  transitCostWon   Int?     @map("transit_cost_won") /// 1회 편도 비용 (원)
  carMinutes       Int      @map("car_minutes") /// 자차 통근시간 (분, Haversine 추정)
  computedAt       DateTime @default(now()) @map("computed_at") /// 캐시 생성 시각 (TTL 산출용)

  @@unique([cacheKey, legalDongCode], map: "uniq_commute")
  @@index([cacheKey])
  @@map("t_commute_matrix")
}
