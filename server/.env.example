PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MySQL (Prisma) 연결 문자열
DATABASE_URL="mysql://root:root@localhost:3306/molit_contest"

# JWT 서명 비밀키 — 32바이트 이상 권장. 운영에서는 절대 공유 금지.
JWT_SECRET="change-me-please-32-bytes-minimum-length-secret"

# 토큰 만료 정책 (ms) — 코드 기본값과 동일. 필요 시 오버라이드 용도.
# ACCESS_TTL_MS=3600000          # 1h
# REFRESH_REMEMBER_TTL_MS=1209600000   # 14d
# REFRESH_DEFAULT_TTL_MS=86400000      # 1d

# 계정 잠금 임계치 (로그인 실패 횟수)
LOGIN_LOCK_THRESHOLD=5
