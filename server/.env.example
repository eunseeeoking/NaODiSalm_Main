PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MySQL (Prisma) 연결 문자열
DATABASE_URL=

# JWT 서명 비밀키 — 32바이트 이상 권장
JWT_SECRET=

# 계정 잠금 임계치
LOGIN_LOCK_THRESHOLD=

# ─────────────────────────────────────────────────────────────
# 국토교통부 공공데이터포털 API 인증키 (data.go.kr 에서 발급)
#   - 디코딩된 키 그대로 입력 (URL 인코딩 없이)
#   - 절대 git 에 커밋 금지
MOLIT_SERVICE_KEY=

# Kakao REST API 키 (server-side 호출용 — JavaScript 키와 다름)
#   - Kakao Developers → 앱 → 앱 키 → REST API 키
#   - 지오코딩(주소→좌표 변환)에 사용
KAKAO_REST_API_KEY=

# 관리자 트리거 토큰 (ingest/geocode 엔드포인트 보호)
#   - openssl rand -hex 32  같은 명령으로 생성
ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────
# ODsay LAB 대중교통 길찾기 API 키 (lab.odsay.com 에서 발급)
#   - 무료: 일 1,000건 / 초 5건 제한 (개인·학생·5인이하 스타트업)
#   - 직장 ↔ 행정동 통근시간 매트릭스 산출 + DB 캐싱에 사용
#   - 절대 git 에 커밋 금지
ODSAY_API_KEY=
