PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MySQL (Prisma) 연결 문자열
DATABASE_URL=

# JWT 서명 비밀키 — 32바이트 이상 권장
JWT_SECRET=

# 계정 잠금 임계치
LOGIN_LOCK_THRESHOLD=

# ─────────────────────────────────────────────────────────────
# 국토교통부 공공데이터포털 API 인증키 (data.go.kr 에서 발급)
#   - 디코딩된 키 그대로 입력 (URL 인코딩 없이)
#   - 절대 git 에 커밋 금지
#   - 하나의 키로 아래 API 전부 커버 (동일 계정에서 각 API 활용신청 필요):
#       · 아파트 실거래가 조회        /1613000/... (기존)
#       · 버스정류장정보 조회 서비스  /1613000/BusSttnInfoInqireService
#       · 버스노선정보 조회 서비스    /1613000/BusRouteInfoInqireService
#       · LH 임대주택 공급정보        (data.go.kr 이관 후 활용신청)
MOLIT_SERVICE_KEY=

# 부동산원 R-ONE 오픈 API 인증키 (www.reb.or.kr/r-one 에서 발급)
#   - 아파트 매매·전세 가격지수(REB) 조회에 사용
#   - 발급: https://www.reb.or.kr/r-one → 오픈API → 사용자등록
#   - 절대 git 에 커밋 금지
R_ONE_KEY=

# Kakao REST API 키 (server-side 호출용 — JavaScript 키와 다름)
#   - Kakao Developers → 앱 → 앱 키 → REST API 키
#   - 지오코딩(주소→좌표 변환)에 사용
KAKAO_REST_API_KEY=

# 관리자 트리거 토큰 (ingest/geocode 엔드포인트 보호)
#   - openssl rand -hex 32  같은 명령으로 생성
ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────
# ODsay LAB 대중교통 길찾기 API 키 (lab.odsay.com 에서 발급)
#   - 무료: 일 1,000건 / 초 5건 제한 (개인·학생·5인이하 스타트업)
#   - 직장 ↔ 행정동 통근시간 매트릭스 산출 + DB 캐싱에 사용
#   - 절대 git 에 커밋 금지
ODSAY_API_KEY=
