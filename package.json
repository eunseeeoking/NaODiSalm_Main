{
  "name": "molit-contest-2026",
  "private": true,
  "version": "0.1.0",
  "description": "2026 MOLIT Contest - Monorepo (client + server)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm-run-all build:server build:client",
    "build:client": "npm --workspace client run build",
    "build:server": "npm --workspace server run build",
    "start": "npm --workspace server run start",
    "lint": "npm-run-all --parallel lint:*",
    "lint:client": "npm --workspace client run lint --if-present",
    "lint:server": "npm --workspace server run lint --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
